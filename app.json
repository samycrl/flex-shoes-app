        "backgroundColor": "#1B6B47"
      },
      "package": "ro.flexshoes.app",
      "versionCode": 1,
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "web": {
      "favicon": "./favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4753a421-f71a-49aa-8582-ef66ae7a3e42"
      }
    },
    "owner": "samycrl"
  }
